        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Willkommen zur Online-Version des Experiments! Die Online-Aufgabe ist gleich dem zweiten Teil der Aufgabe, die Sie vor Ort gemacht haben. Sie bekommen diesmal gleich die Szene dargestellt und sollen anschließend jenes Objekt durch Anklicken auswählen, das mit der entsprechenden Szene verbunden war. Danach wird Ihnen wieder kurz die richtige Lösung präsentiert.&amp;#10;Diese Aufgabe sollen Sie das erste Mal am nächsten Tag und dann alle drei Tage durchführen; d.h. über die kommenden 2 Wochen hinweg insgesamt 5-mal." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
      </TextboxComponent>
      <TextboxComponent name="text_introduction_button" plugin="None">
        <Param val="center" valType="str" updates="constant" name="alignment"/>
